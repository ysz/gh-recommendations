{
  "manifest_version": 3,
  "name": "GitHub Repo Recommendations",
  "version": "0.1.0",
  "description": "Shows similar repository recommendations on GitHub repo pages",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["data/recommendations.json"],
      "matches": ["https://github.com/*"]
    }
  ],
  "action": {},
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
